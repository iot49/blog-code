#!/usr/bin/env bash
set -euo pipefail

# This script now only tests the blog-code theme engine natively.
# Actual blog deployment occurs from the blog-content directory.

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

pass() { echo -e "${GREEN}✓${RESET} $1"; }
fail() { echo -e "${RED}✗${RESET} $1"; }
info() { echo -e "${CYAN}▶${RESET} $1"; }

echo -e "\n${BOLD}=== Testing blog-code theme engine ===${RESET}\n"

ERRORS=0

# ── 1. Prettier ───────────────────────────────────────────────────────────────
info "Prettier (auto-formatting)..."
npm run fix:prettier --silent
pass "Prettier"

# ── 2. ESLint ─────────────────────────────────────────────────────────────────
info "ESLint..."
if npm run check:eslint --silent 2>&1; then
  pass "ESLint"
else
  fail "ESLint — run 'npm run fix:eslint' to auto-fix where possible"
  ERRORS=$((ERRORS + 1))
fi

# ── 3. Astro type check ───────────────────────────────────────────────────────
info "Astro type check..."
if npm run check:astro --silent 2>&1; then
  pass "Astro type check"
else
  fail "Astro type check failed"
  ERRORS=$((ERRORS + 1))
fi

# ── Summary ───────────────────────────────────────────────────────────────────
echo ""
if [[ $ERRORS -gt 0 ]]; then
  echo -e "${RED}${BOLD}✗ $ERRORS check(s) failed in the theme engine.${RESET}"
  exit 1
fi

echo -e "${GREEN}${BOLD}✓ Theme engine checks passed!${RESET}\n"

# ── Sync Code to GitHub ───────────────────────────────────────────────────────
info "Pushing theme code to GitHub..."
git push || echo -e "${YELLOW}⚠ Git push failed or nothing to push.${RESET}"
